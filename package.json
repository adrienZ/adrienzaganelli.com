{
	"name": "adrienzaganelli.com",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"build": "nuxt build",
		"dev": "nuxt dev --dotenv .env.dev --host 0.0.0.0",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "eslint .",
		"check": "run-s format:check lint",
		"generate": "nuxt build --prerender --dotenv .env.dev",
		"prod": "nuxt build --prerender --dotenv .env.prod",
		"test": "pnpm exec playwright test",
		"preview": "nuxt preview --dotenv env.dev",
		"preinstall": "pnpm -v",
		"postinstall": "nuxt prepare",
		"prepare": "husky"
	},
	"dependencies": {
		"@nuxtjs/google-fonts": "^3.2.0",
		"@nzambello/link-previewer": "^1.1.1",
		"@vueuse/core": "^14.3.0",
		"body-scroll-lock": "4.0.0-beta.0",
		"grabity": "^1.0.5",
		"gsap": "^3.15.0",
		"image-size": "^2.0.2",
		"lazysizes": "^5.3.2",
		"mitt": "^3.0.1",
		"radix-vue": "^1.9.17",
		"rellax": "^1.12.1"
	},
	"devDependencies": {
		"@nuxt/content": "^2.13.4",
		"@nuxt/devtools": "4.0.0-alpha.4",
		"@nuxt/eslint": "1.15.2",
		"@nuxt/icon": "^2.3.1",
		"@nuxt/image": "^2.0.0",
		"@nuxt/scripts": "^0.13.4",
		"@nuxtjs/tailwindcss": "^6.14.0",
		"@playwright/test": "^1.61.1",
		"@types/body-scroll-lock": "^3.1.2",
		"@types/node": "^24.12.2",
		"@types/rellax": "^1.7.8",
		"@types/rss": "^0.0.32",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"npm-run-all2": "^8.0.4",
		"nuxt": "^4.4.8",
		"nuxt-umami": "^3.2.1",
		"oxfmt": "^0.24.0",
		"rss": "^1.2.2",
		"sass-easing": "^1.0.3"
	},
	"lint-staged": {
		"**/*": "oxfmt --no-error-on-unmatched-pattern"
	},
	"engines": {
		"node": "24.11.0"
	},
	"packageManager": "pnpm@9.12.3"
}
